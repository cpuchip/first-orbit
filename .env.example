# Copy to .env and fill in. .env is gitignored.

# Google AI Studio key for the image asset pipeline (scripts/gen-assets).
# Free tier: ~500 images/day at no cost. Get one with your Google login at:
#   https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional: override the image model (default: gemini-2.5-flash-image / "Nano Banana").
# GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
